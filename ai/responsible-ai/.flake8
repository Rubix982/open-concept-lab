[flake8]
max-line-length = 88
extend-ignore =
    # E203: whitespace before ':' — conflicts with black slice formatting
    E203,
    # W503: line break before binary operator — conflicts with black
    W503,
    # ANN101/ANN102: annotations for self/cls — not useful noise
    ANN101,
    ANN102,
    # F403/F405: star imports — Manim is designed around `from manim import *`
    F403,
    F405,
per-file-ignores =
    # Test/scratch files don't need full annotation coverage
    animations/test_scene.py: ANN
    # Dialogue strings in lecture scenes cannot be broken at 88 chars
    animations/05_regulation/scene_02_doubt1.py: E501,F401
    animations/05_regulation/scene_03_doubt2.py: E501,F401
    animations/05_regulation/scene_04_doubt3.py: E501
    animations/05_regulation/scene_05_doubt4.py: E501
    animations/05_regulation/scene_06_doubt5.py: E501
    animations/05_regulation/scene_07_doubt6.py: E501
    animations/08_hcai/three_waves_of_ai.py: E501
    # Training data strings cannot be broken mid-literal
    knowledge-graph/claim-classifier/train.py: E501
