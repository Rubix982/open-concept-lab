# Python bytecode and caches
__pycache__/
*.py[cod]
*.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# Data — track generated corpus and knowledge DB, ignore raw/temp files
data/*

# Ground truth (curated, always track)
!data/ground_truth/
data/ground_truth/*
!data/ground_truth/cross_disciplinary_pairs.json

# Pipeline artifacts (track — needed to run knowledge infra without re-fetching)
!data/pipeline/
data/pipeline/*
!data/pipeline/arxiv_10k.parquet
!data/pipeline/embeddings_10k.npy
!data/pipeline/embeddings_10k_checkpoint.json
!data/pipeline/citations_10k_cache.json

# Knowledge DB (track — expensive to regenerate via Ollama)
!data/knowledge/
data/knowledge/*
!data/knowledge/knowledge.db
# SQLite WAL side files — transient, never commit
data/knowledge/*.db-shm
data/knowledge/*.db-wal
artifacts/.cache/
artifacts/.mplconfig/
artifacts/**/*.npy
artifacts/**/*.wal
artifacts/**/*.duckdb

# Notebook and OS noise
.conversations
.DS_Store
